# Caddyfile — auto-SSL reverse proxy
# Generated by /upcloud:setup
#
# Template variables:
#   {domain} — your domain (e.g., myapp.example.com)
#
# Caddy automatically provisions and renews Let's Encrypt TLS certificates.

{domain} {
    reverse_proxy app:8080

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    }

    # Gzip compression
    encode gzip

    # Access log
    log {
        output file /var/log/caddy/access.log
        format json
    }
}

# Redirect www to non-www (optional, uncomment if needed)
# www.{domain} {
#     redir https://{domain}{uri} permanent
# }
